{
  "name": "n8n-nodes-groupwise-imap",
  "version": "0.1.2",
  "description": "n8n community node for Micro Focus / OpenText GroupWise IMAP — create drafts, list mailboxes, fetch, move & delete emails with built-in retry logic and GroupWise-specific compatibility fixes.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "imap",
    "groupwise",
    "micro-focus",
    "opentext",
    "email",
    "draft"
  ],
  "license": "MIT",
  "homepage": "https://www.novalutions.de",
  "author": {
    "name": "novalutions",
    "email": "info@novalutions.de",
    "url": "https://www.novalutions.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/novalutions/n8n-nodes-groupwise-imap.git"
  },
  "bugs": {
    "url": "https://github.com/novalutions/n8n-nodes-groupwise-imap/issues"
  },
  "main": "dist/nodes/GroupwiseImap/GroupwiseImap.node.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/GroupwiseImapApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GroupwiseImap/GroupwiseImap.node.js"
    ]
  },
  "dependencies": {
    "imapflow": "^1.2.13",
    "nodemailer": "^8.0.2"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.1",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.0.0",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.0.0",
    "release-it": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
